<?xml version="1.0" encoding="UTF-8"?>
<svg width="400" height="400" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="400" height="400" fill="#FF6B6B"/>
  
  <!-- Face -->
  <circle cx="200" cy="180" r="80" fill="#FFD166"/>
  
  <!-- Hair -->
  <path d="M120,120 Q200,80 280,120 Q260,60 200,40 Q140,60 120,120Z" fill="#8B4513"/>
  
  <!-- Eyes -->
  <circle cx="170" cy="170" r="12" fill="#333"/>
  <circle cx="230" cy="170" r="12" fill="#333"/>
  
  <!-- Smile -->
  <path d="M160,220 Q200,250 240,220" stroke="#333" stroke-width="8" fill="none" stroke-linecap="round"/>
  
  <!-- Professional Blazer -->
  <rect x="120" y="260" width="160" height="80" fill="#2C3E50" rx="10"/>
  <rect x="140" y="260" width="120" height="40" fill="#34495E" rx="5"/>
  
  <!-- Name Text -->
  <text x="200" y="380" text-anchor="middle" font-family="Arial, sans-serif" font-size="24" fill="white" font-weight="bold">
    Mary George
  </text>
  
  <!-- Title Text -->
  <text x="200" y="410" text-anchor="middle" font-family="Arial, sans-serif" font-size="18" fill="#FFD166">
    Program Director
  </text>
</svg>